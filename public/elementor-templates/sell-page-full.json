            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:20px;background:rgba(255,255,255,0.03);'><p style='font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,0.5);margin-bottom:12px;font-family:Space Grotesk;'>Your Seller Profile</p><div style='display:flex;align-items:center;gap:12px;'><div style='width:40px;height:40px;border-radius:50%;background:rgba(198,40,40,0.1);display:flex;align-items:center;justify-content:center;'><i class='fas fa-user' style='color:#C62828;'></i></div><div><p style='color:#FFFFFF;font-family:Space Grotesk;font-weight:600;font-size:14px;margin:0;'>Seller</p><p style='color:rgba(255,255,255,0.5);font-size:12px;margin:2px 0 0;'>Sign in to build your reputation</p></div></div></div>"
