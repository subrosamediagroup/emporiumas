{
  "title": "MPortiums Featured Listings Section",
  "type": "section",
  "version": "0.4",
  "page_settings": [],
  "content": [
    {
      "id": "featured_section",
      "elType": "section",
      "settings": {
        "background_background": "classic",
        "background_color": "#F9FAFB",
        "border_border": "solid",
        "border_width": { "unit": "px", "top": "1", "right": "0", "bottom": "0", "left": "0" },
        "border_color": "#E5E7EB",
        "padding": { "unit": "px", "top": "80", "right": "0", "bottom": "80", "left": "0" },
        "content_width": { "unit": "px", "size": 1200 }
      },
      "elements": [
        {
          "id": "featured_header_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "featured_header_inner",
              "elType": "section",
              "isInner": true,
              "settings": { "structure": "20" },
              "elements": [
                {
                  "id": "featured_title_col",
                  "elType": "column",
                  "settings": { "_column_size": 70 },
                  "elements": [
                    {
                      "id": "featured_title",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "title": "Trending Gear",
                        "size": "h2",
                        "typography_typography": "custom",
                        "typography_font_family": "Space Grotesk",
                        "typography_font_size": { "unit": "px", "size": 36 },
                        "typography_font_weight": "700"
                      }
                    },
                    {
                      "id": "featured_subtitle",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "editor": "Hot listings picked for you",
                        "text_color": "#5C6370"
                      }
                    }
                  ]
                },
                {
                  "id": "featured_link_col",
                  "elType": "column",
                  "settings": { "_column_size": 30, "align": "flex-end", "content_position": "bottom" },
                  "elements": [
                    {
                      "id": "view_all_link",
                      "elType": "widget",
                      "widgetType": "button",
                      "settings": {
                        "text": "View all →",
                        "link": { "url": "/shop/" },
                        "button_type": "link",
                        "typography_font_family": "Inter",
                        "button_text_color": "#C62828"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
