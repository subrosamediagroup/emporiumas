                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:20px;background:rgba(255,255,255,0.03);'><p style='font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,0.5);margin-bottom:12px;font-family:Space Grotesk;'>Seller</p><div style='display:flex;align-items:center;gap:16px;'><div style='width:48px;height:48px;border-radius:50%;background:rgba(198,40,40,0.1);display:flex;align-items:center;justify-content:center;color:#C62828;font-weight:700;font-family:Space Grotesk;font-size:14px;'>VA</div><div><div style='display:flex;align-items:center;gap:8px;'><strong style='color:#FFFFFF;font-family:Space Grotesk;'>VintageAxes</strong> <i class='fas fa-shield-alt' style='color:#C62828;font-size:14px;'></i></div><div style='font-size:12px;color:rgba(255,255,255,0.5);display:flex;gap:12px;margin-top:4px;'><span><i class='fas fa-star' style='color:#C62828;'></i> 4.9</span><span>34 listings</span><span>Since 2023</span></div></div></div></div>"
              }
