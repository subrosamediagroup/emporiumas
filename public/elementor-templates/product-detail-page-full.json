            {
              "elType": "widget",
              "widgetType": "image-carousel",
              "settings": {
                "carousel": [
                  {"url": "https://images.unsplash.com/photo-1564186763535-ebb21ef5277f?w=800&h=800&fit=crop"},
                  {"url": "https://images.unsplash.com/photo-1510915361894-db8b60106cb1?w=800&h=800&fit=crop"}
