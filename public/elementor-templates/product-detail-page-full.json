                        "border_width": {"top": "1", "right": "1", "bottom": "1", "left": "1", "unit": "px"},
                        "border_color": "rgba(255,255,255,0.2)",
                        "border_radius": {"top": "10", "right": "10", "bottom": "10", "left": "10", "unit": "px"},
                        "width": {"size": 100, "unit": "%"}
