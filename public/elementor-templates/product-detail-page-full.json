    {
      "_comment": "=== BREADCRUMB ===",
      "elType": "section",
      "settings": {
        "padding": {"top": "96", "bottom": "10", "unit": "px"},
        "content_width": {"size": 1200, "unit": "px"},
        "background_color": "#0A0A0A"
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<a href='/shop/' style='color:#C62828;text-decoration:none;font-size:14px;font-weight:500;'><i class='fas fa-arrow-left' style='margin-right:6px;'></i>Back to Shop</a> <span style='color:rgba(255,255,255,0.3);margin:0 8px;'>/</span> <span style='color:rgba(255,255,255,0.5);font-size:14px;'>Guitars & Basses</span>"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "=== PRODUCT DETAIL ===",
      "elType": "section",
      "settings": {
        "content_width": {"size": 1200, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "20", "bottom": "60", "unit": "px"}
