{
  "title": "MPortiums Account Page (Full)",
  "type": "page",
  "version": "0.4",
  "page_settings": {"template": "elementor_canvas"},
  "content": [
    {
      "elType": "section",
      "settings": {
        "padding": {"top": "96", "bottom": "10", "unit": "px"},
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A"
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "My Account",
                "header_size": "h1",
                "typography_font_family": "Space Grotesk",
                "typography_font_weight": "700",
                "typography_font_size": {"size": 30, "unit": "px"},
                "title_color": "#FFFFFF"
              }
            },
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:rgba(255,255,255,0.5);font-size:14px;'>Manage your profile, payment info, and view purchase history</p>"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "Profile Section",
      "elType": "section",
      "settings": {
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "20", "bottom": "10", "unit": "px"}
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:24px;background:rgba(255,255,255,0.03);'><h2 style='font-family:Space Grotesk;font-weight:700;font-size:18px;color:#FFFFFF;display:flex;align-items:center;gap:8px;'><i class='fas fa-user' style='color:#C62828;'></i>Profile</h2><hr style='border-color:rgba(255,255,255,0.1);margin:16px 0;'/></div>"
              }
            },
            {
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "Profile",
                "form_fields": [
                  {"field_type": "email", "field_label": "Email", "width": "100", "placeholder": "you@example.com", "_element_note": "Disabled field"},
                  {"field_type": "text", "field_label": "Display Name", "width": "100", "placeholder": "Your seller name"},
                  {"field_type": "tel", "field_label": "Phone Number", "width": "100", "placeholder": "(555) 123-4567"}
                ],
                "show_submit": "no",
                "input_background_color": "rgba(255,255,255,0.05)",
                "input_border_color": "rgba(255,255,255,0.1)",
                "input_color": "#FFFFFF",
                "label_color": "#FFFFFF"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "Address Section",
      "elType": "section",
      "settings": {
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "10", "bottom": "10", "unit": "px"}
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:24px;background:rgba(255,255,255,0.03);'><h2 style='font-family:Space Grotesk;font-weight:700;font-size:18px;color:#FFFFFF;display:flex;align-items:center;gap:8px;'><i class='fas fa-map-marker-alt' style='color:#C62828;'></i>Address</h2><hr style='border-color:rgba(255,255,255,0.1);margin:16px 0;'/></div>"
              }
            },
            {
              "elType": "widget",
              "widgetType": "form",
              "settings": {
                "form_name": "Address",
                "form_fields": [
                  {"field_type": "text", "field_label": "Street Address", "width": "100", "placeholder": "123 Main St"},
                  {"field_type": "text", "field_label": "City", "width": "50", "placeholder": "Los Angeles"},
                  {"field_type": "text", "field_label": "State", "width": "50", "placeholder": "California"},
                  {"field_type": "text", "field_label": "ZIP Code", "width": "50", "placeholder": "90001"}
                ],
                "show_submit": "no",
                "input_background_color": "rgba(255,255,255,0.05)",
                "input_border_color": "rgba(255,255,255,0.1)",
                "input_color": "#FFFFFF",
                "label_color": "#FFFFFF"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "Payment Section",
      "elType": "section",
      "settings": {
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "10", "bottom": "10", "unit": "px"}
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:24px;background:rgba(255,255,255,0.03);'><h2 style='font-family:Space Grotesk;font-weight:700;font-size:18px;color:#FFFFFF;display:flex;align-items:center;gap:8px;'><i class='fas fa-credit-card' style='color:#C62828;'></i>Payment Information</h2><hr style='border-color:rgba(255,255,255,0.1);margin:16px 0;'/><div style='display:flex;align-items:center;gap:12px;padding:16px;background:rgba(198,40,40,0.05);border:1px solid rgba(198,40,40,0.2);border-radius:8px;'><i class='fas fa-credit-card' style='font-size:20px;color:#C62828;'></i><div><p style='font-weight:600;color:#FFFFFF;margin:0;font-size:14px;'>Payments handled by Stripe</p><p style='color:rgba(255,255,255,0.5);font-size:12px;margin:4px 0 0;'>Your card details are securely managed by Stripe during checkout. We never store your payment information.</p></div></div></div>"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "Save Button",
      "elType": "section",
      "settings": {
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "10", "bottom": "10", "unit": "px"}
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Save Changes",
                "icon": {"value": "fas fa-save", "library": "fa-solid"},
                "size": "lg",
                "background_color": "#C62828",
                "button_text_color": "#FFFFFF",
                "border_radius": {"top": "10", "right": "10", "bottom": "10", "left": "10", "unit": "px"},
                "typography_font_family": "Space Grotesk",
                "typography_font_weight": "600"
              }
            }
          ]
        }
      ]
    },
    {
      "_comment": "Purchase History",
      "elType": "section",
      "settings": {
        "content_width": {"size": 700, "unit": "px"},
        "background_color": "#0A0A0A",
        "padding": {"top": "40", "bottom": "60", "unit": "px"}
      },
      "elements": [
        {
          "elType": "column",
          "settings": {"_column_size": 100},
          "elements": [
            {
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:24px;background:rgba(255,255,255,0.03);'><h2 style='font-family:Space Grotesk;font-weight:700;font-size:18px;color:#FFFFFF;display:flex;align-items:center;gap:8px;'><i class='fas fa-box' style='color:#C62828;'></i>Purchase History</h2><hr style='border-color:rgba(255,255,255,0.1);margin:16px 0;'/><div style='text-align:center;padding:40px 0;'><div style='width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;margin:0 auto;'><i class='fas fa-shopping-bag' style='font-size:28px;color:rgba(255,255,255,0.3);'></i></div><p style='color:#FFFFFF;font-weight:500;font-size:14px;margin-top:12px;'>No purchases yet</p><p style='color:rgba(255,255,255,0.5);font-size:12px;'>Your order history will appear here after your first purchase.</p><a href='/shop/' style='display:inline-block;margin-top:16px;padding:8px 16px;border:1px solid rgba(255,255,255,0.2);border-radius:8px;color:rgba(255,255,255,0.7);text-decoration:none;font-size:14px;'>Browse Shop</a></div></div>"
              }
            }
          ]
        }
      ]
    }
  ]
}
