{
  "title": "MPortiums Shop Page (Full)",
  "type": "page",
  "version": "0.4",
  "page_settings": {
    "template": "elementor_canvas",
    "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0" }
  },
  "content": [
    {
      "id": "shop_header_section",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 1200 },
        "padding": { "unit": "px", "top": "96", "right": "16", "bottom": "0", "left": "16" }
      },
      "elements": [
        {
          "id": "shop_header_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "shop_header_inner",
              "elType": "section",
              "isInner": true,
              "settings": {
                "structure": "20"
              },
              "elements": [
                {
                  "id": "shop_title_col",
                  "elType": "column",
                  "settings": { "_column_size": 50 },
                  "elements": [
                    {
                      "id": "shop_title",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "title": "Shop Gear",
                        "header_size": "h1",
                        "typography_font_family": "Space Grotesk",
                        "typography_font_size": { "unit": "px", "size": 30 },
                        "typography_font_weight": "700",
                        "title_color": "#1A1A2E"
                      }
                    },
                    {
                      "id": "shop_count",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "editor": "<p id='shopCount' style='font-size:14px;color:#5C6370;'>6 items found</p>"
                      }
                    }
                  ]
                },
                {
                  "id": "shop_sort_col",
                  "elType": "column",
                  "settings": { "_column_size": 50, "align": "flex-end" },
                  "elements": [
                    {
                      "id": "shop_sort_widget",
                      "elType": "widget",
                      "widgetType": "html",
                      "settings": {
                        "html": "<div style=\"display:flex;align-items:center;gap:12px;justify-content:flex-end;\"><button class=\"btn btn-outline btn-sm shop-filter-toggle\" onclick=\"document.getElementById('mobileFilters').classList.toggle('open')\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"4\" y1=\"21\" x2=\"4\" y2=\"14\"/><line x1=\"4\" y1=\"10\" x2=\"4\" y2=\"3\"/><line x1=\"12\" y1=\"21\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"3\"/><line x1=\"20\" y1=\"21\" x2=\"20\" y2=\"16\"/><line x1=\"20\" y1=\"12\" x2=\"20\" y2=\"3\"/></svg> Filters</button><div style=\"position:relative;\"><select id=\"sortSelect\" onchange=\"sortProducts()\" style=\"appearance:none;border:1px solid #E2E8F0;border-radius:8px;padding:8px 32px 8px 12px;font-size:14px;background:#fff;color:#1A1A2E;cursor:pointer;\"><option>Newest</option><option>Price: Low to High</option><option>Price: High to Low</option></select><svg style=\"position:absolute;right:8px;top:50%;transform:translateY(-50%);pointer-events:none;\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#5C6370\" stroke-width=\"2\"><polyline points=\"6 9 12 15 18 9\"/></svg></div></div>"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "shop_body_section",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": { "unit": "px", "size": 1200 },
        "padding": { "unit": "px", "top": "0", "right": "16", "bottom": "64", "left": "16" },
        "structure": "22",
        "gap": "extended"
      },
      "elements": [
        {
          "id": "shop_sidebar_col",
          "elType": "column",
          "settings": {
            "_column_size": 25,
            "hide_mobile": "hidden-phone"
          },
          "elements": [
            {
              "id": "filter_category",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"filter-section\"><h4 class=\"filter-title\">Category</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?category=Guitars+%26+Basses\" class=\"filter-link\">Guitars &amp; Basses</a></li><li><a href=\"/shop/?category=Synthesizers\" class=\"filter-link\">Synthesizers</a></li><li><a href=\"/shop/?category=Headphones\" class=\"filter-link\">Headphones</a></li><li><a href=\"/shop/?category=Speakers+%26+Monitors\" class=\"filter-link\">Speakers &amp; Monitors</a></li><li><a href=\"/shop/?category=Microphones\" class=\"filter-link\">Microphones</a></li><li><a href=\"/shop/?category=DJ+Equipment\" class=\"filter-link\">DJ Equipment</a></li></ul></div>"
              }
            },
            {
              "id": "filter_price",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"filter-section\"><h4 class=\"filter-title\">Price Range</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?price_min=0&price_max=25000\" class=\"filter-link\">Under $250</a></li><li><a href=\"/shop/?price_min=25000&price_max=50000\" class=\"filter-link\">$250 – $500</a></li><li><a href=\"/shop/?price_min=50000&price_max=100000\" class=\"filter-link\">$500 – $1,000</a></li><li><a href=\"/shop/?price_min=100000&price_max=200000\" class=\"filter-link\">$1,000 – $2,000</a></li><li><a href=\"/shop/?price_min=200000&price_max=0\" class=\"filter-link\">$2,000+</a></li></ul></div>"
              }
            },
            {
              "id": "filter_condition",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"filter-section\"><h4 class=\"filter-title\">Condition</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?condition=Like+New\" class=\"filter-link\">Like New</a></li><li><a href=\"/shop/?condition=Excellent\" class=\"filter-link\">Excellent</a></li><li><a href=\"/shop/?condition=Good\" class=\"filter-link\">Good</a></li><li><a href=\"/shop/?condition=Fair\" class=\"filter-link\">Fair</a></li></ul></div>"
              }
            },
            {
              "id": "filter_clear",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<a href=\"/shop/\" class=\"btn btn-outline btn-sm btn-full\">✕ Clear Filters</a>"
              }
            }
          ]
        },
        {
          "id": "shop_grid_col",
          "elType": "column",
          "settings": { "_column_size": 75 },
          "elements": [
            {
              "id": "shop_grid_widget",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"listing-grid\" id=\"shopGrid\"></div><div class=\"empty-state\" id=\"shopEmpty\" style=\"display:none;text-align:center;padding:80px 0;\"><p style=\"font-size:18px;font-weight:600;color:#1A1A2E;\">No items match your filters</p><p style=\"font-size:14px;color:#5C6370;margin-top:4px;\">Try adjusting your criteria</p><a href=\"/shop/\" class=\"btn btn-outline btn-sm\" style=\"margin-top:16px;\">Clear Filters</a></div>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "shop_mobile_filters_section",
      "elType": "section",
      "settings": {},
      "elements": [
        {
          "id": "mobile_filters_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "mobile_filters_widget",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div id=\"mobileFilters\" class=\"mobile-filters-panel\"><div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;\"><h3 style=\"font-family:'Space Grotesk',sans-serif;font-size:18px;font-weight:700;color:#1A1A2E;\">Filters</h3><button onclick=\"document.getElementById('mobileFilters').classList.remove('open')\" style=\"background:none;border:none;cursor:pointer;padding:8px;\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1A1A2E\" stroke-width=\"2\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg></button></div><div class=\"filter-section\"><h4 class=\"filter-title\">Category</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?category=Guitars+%26+Basses\" class=\"filter-link\">Guitars &amp; Basses</a></li><li><a href=\"/shop/?category=Synthesizers\" class=\"filter-link\">Synthesizers</a></li><li><a href=\"/shop/?category=Headphones\" class=\"filter-link\">Headphones</a></li><li><a href=\"/shop/?category=Speakers+%26+Monitors\" class=\"filter-link\">Speakers &amp; Monitors</a></li><li><a href=\"/shop/?category=Microphones\" class=\"filter-link\">Microphones</a></li><li><a href=\"/shop/?category=DJ+Equipment\" class=\"filter-link\">DJ Equipment</a></li></ul></div><div class=\"filter-section\"><h4 class=\"filter-title\">Price Range</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?price_min=0&price_max=25000\" class=\"filter-link\">Under $250</a></li><li><a href=\"/shop/?price_min=25000&price_max=50000\" class=\"filter-link\">$250 – $500</a></li><li><a href=\"/shop/?price_min=50000&price_max=100000\" class=\"filter-link\">$500 – $1,000</a></li><li><a href=\"/shop/?price_min=100000&price_max=200000\" class=\"filter-link\">$1,000 – $2,000</a></li><li><a href=\"/shop/?price_min=200000&price_max=0\" class=\"filter-link\">$2,000+</a></li></ul></div><div class=\"filter-section\"><h4 class=\"filter-title\">Condition</h4><ul class=\"filter-list\"><li><a href=\"/shop/\" class=\"filter-link\">All</a></li><li><a href=\"/shop/?condition=Like+New\" class=\"filter-link\">Like New</a></li><li><a href=\"/shop/?condition=Excellent\" class=\"filter-link\">Excellent</a></li><li><a href=\"/shop/?condition=Good\" class=\"filter-link\">Good</a></li><li><a href=\"/shop/?condition=Fair\" class=\"filter-link\">Fair</a></li></ul></div><a href=\"/shop/\" class=\"btn btn-outline btn-sm btn-full\">✕ Clear Filters</a></div>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "shop_styles_section",
      "elType": "section",
      "settings": {},
      "elements": [
        {
          "id": "shop_styles_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "shop_css_widget",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<style>.filter-list{list-style:none;padding:0;margin:0 0 1.5rem}.filter-link{display:block;padding:6px 12px;border-radius:6px;color:#5C6370;text-decoration:none;font-size:14px;transition:background .15s,color .15s}.filter-link:hover{background:rgba(198,40,40,.08);color:#C62828}.filter-link.active{background:rgba(198,40,40,.12);color:#C62828;font-weight:600}.filter-title{font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#5C6370;margin-bottom:12px}.filter-section{margin-bottom:24px}.listing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.product-card{overflow:hidden;border-radius:12px;border:1px solid #E2E8F0;background:#fff;transition:border-color .2s,transform .2s;cursor:pointer}.product-card:hover{border-color:rgba(198,40,40,.3);transform:translateY(-4px)}.product-image{position:relative;aspect-ratio:1;overflow:hidden;background:#F8FAFC}.product-image img{width:100%;height:100%;object-fit:cover;transition:transform .5s}.product-card:hover .product-image img{transform:scale(1.05)}.product-badge{position:absolute;left:12px;top:12px;background:rgba(255,255,255,.7);backdrop-filter:blur(8px);padding:4px 10px;border-radius:6px;font-size:12px;font-weight:500;color:#1A1A2E}.product-heart{position:absolute;right:12px;top:12px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(255,255,255,.7);backdrop-filter:blur(8px);border:none;cursor:pointer;color:#5C6370;transition:color .2s}.product-heart:hover{color:#C62828}.product-info{padding:16px}.product-category{font-size:12px;color:#5C6370;margin-bottom:2px}.product-title{font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:600;color:#1A1A2E;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.product-price{font-family:'Space Grotesk',sans-serif;font-size:20px;font-weight:700;color:#C62828;margin-bottom:12px}.product-meta{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:#5C6370}.product-seller{display:flex;align-items:center;gap:6px}.product-rating{display:flex;align-items:center;gap:4px}.mobile-filters-panel{position:fixed;inset:0;z-index:50;background:#fff;padding:24px;transform:translateX(-100%);transition:transform .3s ease;overflow-y:auto}.mobile-filters-panel.open{transform:translateX(0)}.shop-filter-toggle{display:none!important}@media(max-width:1024px){.listing-grid{grid-template-columns:repeat(2,1fr)}.shop-filter-toggle{display:flex!important}}@media(max-width:640px){.listing-grid{grid-template-columns:1fr}}.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 20px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;transition:all .2s;text-decoration:none}.btn-outline{background:transparent;border:1px solid #E2E8F0;color:#1A1A2E}.btn-outline:hover{background:#F8FAFC}.btn-sm{padding:6px 14px;font-size:13px}.btn-full{width:100%}</style>"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "shop_script_section",
      "elType": "section",
      "settings": {},
      "elements": [
        {
          "id": "shop_script_col",
          "elType": "column",
          "settings": { "_column_size": 100 },
          "elements": [
            {
              "id": "shop_script_widget",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<script>var sampleProducts=[{id:'sample-1',title:\"Fender Stratocaster '62 Reissue\",price:145000,condition:'Excellent',category:'Guitars & Basses',seller:'VintageAxes',rating:4.9,verified:true,image:'https://images.unsplash.com/photo-1564186763535-ebb21ef5277f?w=400&h=400&fit=crop'},{id:'sample-2',title:'Roland Juno-106 Synthesizer',price:280000,condition:'Good',category:'Synthesizers',seller:'SynthWizard',rating:5.0,verified:true,image:'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?w=400&h=400&fit=crop'},{id:'sample-3',title:'Sennheiser HD 650 Headphones',price:28000,condition:'Like New',category:'Headphones',seller:'AudioPhile99',rating:4.8,verified:false,image:'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&h=400&fit=crop'},{id:'sample-4',title:'Yamaha HS8 Studio Monitors (Pair)',price:52000,condition:'Excellent',category:'Speakers & Monitors',seller:'StudioGear',rating:4.7,verified:true,image:'https://images.unsplash.com/photo-1545454675-3531b543be5d?w=400&h=400&fit=crop'},{id:'sample-5',title:'Shure SM7B Microphone',price:34000,condition:'Like New',category:'Microphones',seller:'ProAudioDeals',rating:4.9,verified:true,image:'https://images.unsplash.com/photo-1590602847861-f357a9332bbc?w=400&h=400&fit=crop'},{id:'sample-6',title:'Pioneer CDJ-2000NXS2',price:160000,condition:'Good',category:'DJ Equipment',seller:'DJDepot',rating:4.6,verified:false,image:'https://images.unsplash.com/photo-1571327073757-71d13c24de30?w=400&h=400&fit=crop'}];function getParams(){var p=new URLSearchParams(window.location.search);return{category:p.get('category')||'',condition:p.get('condition')||'',price_min:p.get('price_min')?parseInt(p.get('price_min')):null,price_max:p.get('price_max')?parseInt(p.get('price_max')):null}}function renderProducts(){var params=getParams();var filtered=sampleProducts.filter(function(p){if(params.category&&p.category!==params.category)return false;if(params.condition&&p.condition!==params.condition)return false;if(params.price_min!==null&&p.price<params.price_min)return false;if(params.price_max!==null&&params.price_max>0&&p.price>params.price_max)return false;return true});var sort=document.getElementById('sortSelect');if(sort){var v=sort.value;if(v==='Price: Low to High')filtered.sort(function(a,b){return a.price-b.price});if(v==='Price: High to Low')filtered.sort(function(a,b){return b.price-a.price})}var grid=document.getElementById('shopGrid');var empty=document.getElementById('shopEmpty');var count=document.getElementById('shopCount');if(count)count.textContent=filtered.length+' items found';if(filtered.length===0){if(grid)grid.style.display='none';if(empty)empty.style.display='block';return}if(grid)grid.style.display='';if(empty)empty.style.display='none';if(grid)grid.innerHTML=filtered.map(function(item){return'<a href=\"/product/'+item.id+'\" style=\"text-decoration:none;color:inherit;\"><div class=\"product-card\"><div class=\"product-image\"><img src=\"'+item.image+'\" alt=\"'+item.title+'\" loading=\"lazy\"/><span class=\"product-badge\">'+item.condition+'</span><button class=\"product-heart\" onclick=\"event.preventDefault()\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg></button></div><div class=\"product-info\"><p class=\"product-category\">'+item.category+'</p><h3 class=\"product-title\">'+item.title+'</h3><p class=\"product-price\">$'+(item.price/100).toLocaleString()+'</p><div class=\"product-meta\"><div class=\"product-seller\">'+(item.verified?'<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#C62828\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>':'')+item.seller+'</div>'+(item.rating>0?'<div class=\"product-rating\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"#C62828\" stroke=\"#C62828\" stroke-width=\"2\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg>'+item.rating+'</div>':'')+'</div></div></div></a>'}).join('');highlightActiveFilters(params)}function highlightActiveFilters(params){document.querySelectorAll('.filter-link').forEach(function(link){link.classList.remove('active');var href=link.getAttribute('href');var u=new URL(href,window.location.origin);var lp=new URLSearchParams(u.search);var isAllLink=!lp.get('category')&&!lp.get('condition')&&!lp.get('price_min');if(!params.category&&!params.condition&&params.price_min===null){if(isAllLink)link.classList.add('active')}else{if(params.category&&lp.get('category')===params.category)link.classList.add('active');if(params.condition&&lp.get('condition')===params.condition)link.classList.add('active');if(params.price_min!==null&&lp.get('price_min')&&parseInt(lp.get('price_min'))===params.price_min)link.classList.add('active');if(!params.category&&!params.condition&&params.price_min===null&&isAllLink)link.classList.add('active')}})}function sortProducts(){renderProducts()}document.addEventListener('DOMContentLoaded',renderProducts);</script>"
              }
            }
          ]
        }
      ]
    }
  ]
}