[
  {
    "id": "header-section",
    "elType": "section",
    "settings": {
      "structure": "20",
      "background_background": "classic",
      "background_color": "rgba(255,255,255,0.8)",
      "border_border": "solid",
      "border_width": { "unit": "px", "top": "0", "right": "0", "bottom": "1", "left": "0" },
      "border_color": "#E5E7EB",
      "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0" },
      "z_index": 50,
      "sticky": "top",
      "css_classes": "navbar"
    },
    "elements": [
      {
        "id": "header-row",
        "elType": "column",
        "settings": {
          "content_position": "center",
          "_column_size": 100
        },
        "elements": [
          {
            "id": "header-inner",
            "elType": "section",
            "settings": {
              "structure": "30",
              "content_width": { "unit": "px", "size": 1280 },
              "height": { "unit": "px", "size": 64 },
              "gap": "no"
            },
            "elements": [
              {
                "id": "col-logo-nav",
                "elType": "column",
                "settings": {
                  "_column_size": 33,
                  "content_position": "center"
                },
                "elements": [
                  {
                    "id": "site-logo",
                    "elType": "widget",
                    "widgetType": "image",
                    "settings": {
                      "image": { "url": "/images/mporiums-logo.png" },
                      "image_size": "custom",
                      "image_custom_dimension": { "width": "auto", "height": 32 },
                      "link": { "url": "/" },
                      "css_classes": "logo"
                    }
                  },
                  {
                    "id": "nav-menu",
                    "elType": "widget",
                    "widgetType": "nav-menu",
                    "settings": {
                      "menu": "primary-menu",
                      "layout": "horizontal",
                      "align_items": "center",
                      "pointer": "none",
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "500",
                      "text_color": "#6B7280",
                      "text_color_hover": "#1A1A2E",
                      "gap_between_items": { "unit": "px", "size": 24 },
                      "menu_items": [
                        { "title": "Shop", "url": "/shop/" },
                        { "title": "Sell", "url": "/sell/" },
                        { "title": "Deals", "url": "#" },
                        { "title": "Community", "url": "#" }
                      ],
                      "hide_on": "mobile",
                      "css_classes": "nav-links"
                    }
                  }
                ]
              },
              {
                "id": "col-search",
                "elType": "column",
                "settings": {
                  "_column_size": 34,
                  "content_position": "center",
                  "align": "center"
                },
                "elements": [
                  {
                    "id": "search-form",
                    "elType": "widget",
                    "widgetType": "search-form",
                    "settings": {
                      "placeholder": "Search gear, instruments, brands...",
                      "skin": "minimal",
                      "input_typography_font_family": "Inter",
                      "input_typography_font_size": { "unit": "px", "size": 14 },
                      "input_background_color": "#F3F4F6",
                      "input_border_border": "solid",
                      "input_border_width": { "unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1" },
                      "input_border_color": "#E5E7EB",
                      "input_border_radius": { "unit": "px", "top": "8", "right": "8", "bottom": "8", "left": "8" },
                      "input_padding": { "unit": "px", "top": "8", "right": "12", "bottom": "8", "left": "40" },
                      "icon_color": "#6B7280",
                      "hide_on": "mobile",
                      "css_classes": "search-bar"
                    }
                  }
                ]
              },
              {
                "id": "col-actions",
                "elType": "column",
                "settings": {
                  "_column_size": 33,
                  "content_position": "center",
                  "align": "right"
                },
                "elements": [
                  {
                    "id": "theme-toggle-btn",
                    "elType": "widget",
                    "widgetType": "button",
                    "settings": {
                      "text": "",
                      "button_type": "info",
                      "size": "xs",
                      "icon": { "value": "fas fa-sun", "library": "fa-solid" },
                      "background_color": "transparent",
                      "text_color": "#6B7280",
                      "hover_color": "#1A1A2E",
                      "border_border": "none",
                      "button_css_id": "themeToggle",
                      "css_classes": "btn btn-ghost icon-btn"
                    }
                  },
                  {
                    "id": "cart-btn",
                    "elType": "widget",
                    "widgetType": "button",
                    "settings": {
                      "text": "",
                      "button_type": "info",
                      "size": "xs",
                      "icon": { "value": "fas fa-shopping-cart", "library": "fa-solid" },
                      "link": { "url": "/cart/" },
                      "background_color": "transparent",
                      "text_color": "#6B7280",
                      "hover_color": "#1A1A2E",
                      "border_border": "none",
                      "css_classes": "btn btn-ghost icon-btn cart-btn",
                      "badge_text": "0",
                      "badge_css_id": "cartBadge"
                    }
                  },
                  {
                    "id": "sign-in-btn",
                    "elType": "widget",
                    "widgetType": "button",
                    "settings": {
                      "text": "Sign In",
                      "button_type": "default",
                      "size": "sm",
                      "link": { "url": "/auth/" },
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "500",
                      "background_color": "#E3232C",
                      "text_color": "#FFFFFF",
                      "border_radius": { "unit": "px", "top": "6", "right": "6", "bottom": "6", "left": "6" },
                      "padding": { "unit": "px", "top": "8", "right": "16", "bottom": "8", "left": "16" },
                      "hide_on": "mobile",
                      "css_classes": "btn btn-primary"
                    }
                  },
                  {
                    "id": "mobile-menu-btn",
                    "elType": "widget",
                    "widgetType": "button",
                    "settings": {
                      "text": "",
                      "button_type": "info",
                      "size": "xs",
                      "icon": { "value": "fas fa-bars", "library": "fa-solid" },
                      "background_color": "transparent",
                      "text_color": "#6B7280",
                      "border_border": "none",
                      "button_css_id": "mobileMenuBtn",
                      "show_on": "mobile",
                      "css_classes": "btn btn-ghost icon-btn show-mobile"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "id": "mobile-menu-section",
    "elType": "section",
    "settings": {
      "structure": "10",
      "background_background": "classic",
      "background_color": "#FFFFFF",
      "border_border": "solid",
      "border_width": { "unit": "px", "top": "1", "right": "0", "bottom": "0", "left": "0" },
      "border_color": "#E5E7EB",
      "padding": { "unit": "px", "top": "16", "right": "16", "bottom": "16", "left": "16" },
      "show_on": "mobile",
      "css_classes": "mobile-menu",
      "css_id": "mobileMenu"
    },
    "elements": [
      {
        "id": "mobile-menu-col",
        "elType": "column",
        "settings": { "_column_size": 100 },
        "elements": [
          {
            "id": "mobile-search",
            "elType": "widget",
            "widgetType": "search-form",
            "settings": {
              "placeholder": "Search gear...",
              "skin": "minimal",
              "input_typography_font_family": "Inter",
              "input_typography_font_size": { "unit": "px", "size": 14 },
              "input_background_color": "#F3F4F6",
              "input_border_border": "solid",
              "input_border_width": { "unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1" },
              "input_border_color": "#E5E7EB",
              "input_border_radius": { "unit": "px", "top": "8", "right": "8", "bottom": "8", "left": "8" },
              "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0" },
              "css_classes": "mobile-search"
            }
          },
          {
            "id": "mobile-nav-links",
            "elType": "widget",
            "widgetType": "icon-list",
            "settings": {
              "icon_list": [
                { "text": "Shop", "link": { "url": "/shop/" } },
                { "text": "Sell", "link": { "url": "/sell/" } },
                { "text": "Deals", "link": { "url": "#" } },
                { "text": "Community", "link": { "url": "#" } }
              ],
              "typography_typography": "custom",
              "typography_font_family": "Inter",
              "typography_font_size": { "unit": "px", "size": 14 },
              "typography_font_weight": "500",
              "text_color": "#6B7280",
              "text_color_hover": "#1A1A2E",
              "space_between": { "unit": "px", "size": 0 },
              "icon_size": { "unit": "px", "size": 0 },
              "css_classes": "mobile-links"
            }
          },
          {
            "id": "mobile-sign-in",
            "elType": "widget",
            "widgetType": "button",
            "settings": {
              "text": "Sign In / Sign Up",
              "button_type": "default",
              "size": "sm",
              "link": { "url": "/auth/" },
              "typography_typography": "custom",
              "typography_font_family": "Inter",
              "typography_font_size": { "unit": "px", "size": 14 },
              "typography_font_weight": "500",
              "text_color": "#E3232C",
              "background_color": "transparent",
              "border_border": "none",
              "align": "left",
              "css_classes": "mobile-link"
            }
          }
        ]
      }
    ]
  }
]