[
  {
    "id": "footer-section",
    "elType": "section",
    "settings": {
      "structure": "10",
      "background_background": "classic",
      "background_color": "#FFFFFF",
      "border_border": "solid",
      "border_width": { "unit": "px", "top": "1", "right": "0", "bottom": "0", "left": "0" },
      "border_color": "#E5E7EB",
      "padding": { "unit": "px", "top": "64", "right": "0", "bottom": "64", "left": "0" },
      "css_classes": "footer"
    },
    "elements": [
      {
        "id": "footer-container",
        "elType": "column",
        "settings": {
          "_column_size": 100,
          "content_width": { "unit": "px", "size": 1280 }
        },
        "elements": [
          {
            "id": "footer-grid",
            "elType": "section",
            "settings": {
              "structure": "40",
              "gap": "extended",
              "css_classes": "footer-grid"
            },
            "elements": [
              {
                "id": "footer-col-brand",
                "elType": "column",
                "settings": { "_column_size": 25 },
                "elements": [
                  {
                    "id": "footer-logo",
                    "elType": "widget",
                    "widgetType": "image",
                    "settings": {
                      "image": { "url": "/images/mporiums-logo.png" },
                      "image_size": "custom",
                      "image_custom_dimension": { "width": "auto", "height": 32 },
                      "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0" }
                    }
                  },
                  {
                    "id": "footer-tagline",
                    "elType": "widget",
                    "widgetType": "text-editor",
                    "settings": {
                      "editor": "The trusted marketplace for buying and selling audio hardware and musical instruments.",
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "400",
                      "text_color": "#6B7280"
                    }
                  }
                ]
              },
              {
                "id": "footer-col-marketplace",
                "elType": "column",
                "settings": { "_column_size": 25 },
                "elements": [
                  {
                    "id": "footer-heading-marketplace",
                    "elType": "widget",
                    "widgetType": "heading",
                    "settings": {
                      "title": "Marketplace",
                      "header_size": "h4",
                      "typography_typography": "custom",
                      "typography_font_family": "Space Grotesk",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "600",
                      "title_color": "#1A1A2E",
                      "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0" },
                      "css_classes": "footer-heading"
                    }
                  },
                  {
                    "id": "footer-links-marketplace",
                    "elType": "widget",
                    "widgetType": "icon-list",
                    "settings": {
                      "icon_list": [
                        { "text": "Shop All", "link": { "url": "/shop/" } },
                        { "text": "Sell Gear", "link": { "url": "/sell/" } },
                        { "text": "Price Guide", "link": { "url": "#" } },
                        { "text": "Deals", "link": { "url": "#" } }
                      ],
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "400",
                      "text_color": "#6B7280",
                      "text_color_hover": "#1A1A2E",
                      "space_between": { "unit": "px", "size": 8 },
                      "icon_size": { "unit": "px", "size": 0 },
                      "css_classes": "footer-links"
                    }
                  }
                ]
              },
              {
                "id": "footer-col-support",
                "elType": "column",
                "settings": { "_column_size": 25 },
                "elements": [
                  {
                    "id": "footer-heading-support",
                    "elType": "widget",
                    "widgetType": "heading",
                    "settings": {
                      "title": "Support",
                      "header_size": "h4",
                      "typography_typography": "custom",
                      "typography_font_family": "Space Grotesk",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "600",
                      "title_color": "#1A1A2E",
                      "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0" },
                      "css_classes": "footer-heading"
                    }
                  },
                  {
                    "id": "footer-links-support",
                    "elType": "widget",
                    "widgetType": "icon-list",
                    "settings": {
                      "icon_list": [
                        { "text": "Help Center", "link": { "url": "#" } },
                        { "text": "Buyer Protection", "link": { "url": "#" } },
                        { "text": "Shipping Info", "link": { "url": "#" } },
                        { "text": "Returns", "link": { "url": "#" } }
                      ],
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "400",
                      "text_color": "#6B7280",
                      "text_color_hover": "#1A1A2E",
                      "space_between": { "unit": "px", "size": 8 },
                      "icon_size": { "unit": "px", "size": 0 },
                      "css_classes": "footer-links"
                    }
                  }
                ]
              },
              {
                "id": "footer-col-company",
                "elType": "column",
                "settings": { "_column_size": 25 },
                "elements": [
                  {
                    "id": "footer-heading-company",
                    "elType": "widget",
                    "widgetType": "heading",
                    "settings": {
                      "title": "Company",
                      "header_size": "h4",
                      "typography_typography": "custom",
                      "typography_font_family": "Space Grotesk",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "600",
                      "title_color": "#1A1A2E",
                      "margin": { "unit": "px", "top": "0", "right": "0", "bottom": "16", "left": "0" },
                      "css_classes": "footer-heading"
                    }
                  },
                  {
                    "id": "footer-links-company",
                    "elType": "widget",
                    "widgetType": "icon-list",
                    "settings": {
                      "icon_list": [
                        { "text": "About Us", "link": { "url": "#" } },
                        { "text": "Careers", "link": { "url": "#" } },
                        { "text": "Blog", "link": { "url": "#" } },
                        { "text": "Contact", "link": { "url": "#" } }
                      ],
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 14 },
                      "typography_font_weight": "400",
                      "text_color": "#6B7280",
                      "text_color_hover": "#1A1A2E",
                      "space_between": { "unit": "px", "size": 8 },
                      "icon_size": { "unit": "px", "size": 0 },
                      "css_classes": "footer-links"
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "footer-bottom-section",
            "elType": "section",
            "settings": {
              "structure": "10",
              "border_border": "solid",
              "border_width": { "unit": "px", "top": "1", "right": "0", "bottom": "0", "left": "0" },
              "border_color": "#E5E7EB",
              "margin": { "unit": "px", "top": "48", "right": "0", "bottom": "0", "left": "0" },
              "padding": { "unit": "px", "top": "32", "right": "0", "bottom": "0", "left": "0" },
              "css_classes": "footer-bottom"
            },
            "elements": [
              {
                "id": "footer-bottom-col",
                "elType": "column",
                "settings": {
                  "_column_size": 100,
                  "align": "center"
                },
                "elements": [
                  {
                    "id": "footer-copyright",
                    "elType": "widget",
                    "widgetType": "text-editor",
                    "settings": {
                      "editor": "© 2026 M.Poriums. All rights reserved.",
                      "align": "center",
                      "typography_typography": "custom",
                      "typography_font_family": "Inter",
                      "typography_font_size": { "unit": "px", "size": 12 },
                      "typography_font_weight": "400",
                      "text_color": "#6B7280"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
]